APP_NAME="Yasser Hosny Portfolio API"
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS="http://localhost:4200,http://localhost:8080"

# --- Contact form: Zoho SMTP (iron-sys.com) ------------------------------
# Region-specific host: smtp.zoho.com (US), smtp.zoho.eu (EU), etc.
# Generate an *app-specific* password from Zoho Mail → Settings →
# Security → App Passwords. Never use your regular login password.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=your-user@iron-sys.com
SMTP_PASSWORD=your-zoho-app-password
CONTACT_FROM_EMAIL=your-user@iron-sys.com
CONTACT_FROM_NAME="Yasser Hosny Portfolio"
CONTACT_TO_EMAIL=you@iron-sys.com
CONTACT_RATE_LIMIT="5/hour"

# --- Phase 2: Supabase persistence ---------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
